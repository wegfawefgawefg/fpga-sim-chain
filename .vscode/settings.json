{
  "files.associations": {
    "*.shdl": "shdl"
  },
  "[shdl]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "\\.shdl$",
        "cmd": "PYTHONPATH=src .venv/bin/python scripts/format_shdl.py ${file}"
      }
    ]
  }
}
